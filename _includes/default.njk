<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
  </head>
  <body>
    <main>
      <article>
        <h1>{{ title }}</h1>
        {{ content | safe }}
      </article>
      <p><a href="/">← All articles</a> · <a href="/post/{{ page.fileSlug }}.md">View raw Markdown</a></p>
    </main>
  </body>
</html>
