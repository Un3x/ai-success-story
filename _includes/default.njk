<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
  </head>
  <body>
    <header>
      <p><a href="{{ "/" | url }}">AI Success Story</a></p>
    </header>
    <main>
      <article>
        <h1>{{ title }}</h1>
        {{ content | safe }}
      </article>
      <p><a href="{{ "/" | url }}">← All articles</a> · <a href="{{ ("/post/" + page.fileSlug + ".md") | url }}">View raw Markdown</a></p>
    </main>
  </body>
</html>
