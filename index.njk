<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
  </head>
  <body>
    <main>
      <h1>{{ title }}</h1>
      <ul>
        {% for post in collections.articles %}
          <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <small>— {{ post.date.toISOString().slice(0, 10) }}</small>
          </li>
        {% endfor %}
      </ul>
    </main>
  </body>
</html>
